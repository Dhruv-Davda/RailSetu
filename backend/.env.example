# RailSetu backend configuration. Copy to `.env` and edit. All vars are prefixed
# RAILSETU_. `.env` is git-ignored — never commit real API keys.

# ---- App ----
RAILSETU_LOG_LEVEL=INFO
# Comma-separated, or a JSON list. Lock this down in production (don't ship "*").
RAILSETU_CORS_ORIGINS=*

# ---- Station ----
RAILSETU_STATION_CODE=NDLS
# Allow POST /api/station/refresh to hot-reload the graph fixture after a rebuild.
RAILSETU_ALLOW_GRAPH_REFRESH=false

# ---- Demand provider ----
# "fixture" = committed scenarios (default, network-free). "live" = third-party API.
RAILSETU_DEMAND_PROVIDER=fixture
RAILSETU_LIVE_FALLBACK_TO_FIXTURE=true

# ---- Third-party (RapidAPI) live rail API ----
# Get a key from RapidAPI for an "Indian Railways" provider (e.g. irctc1), then set:
RAILSETU_RAIL_API_KEY=
RAILSETU_RAIL_API_HOST=irctc1.p.rapidapi.com
RAILSETU_RAIL_API_BASE_URL=https://irctc1.p.rapidapi.com
# Source: "timetable" (getTrainsByStation, time-filtered — populated/reliable) or
# "liveboard" (getLiveStation, delay-adjusted but often empty / rate-limited).
RAILSETU_RAIL_API_SOURCE=timetable
RAILSETU_RAIL_API_TIMETABLE_PATH=/api/v3/getTrainsByStation
RAILSETU_RAIL_API_LIVE_PATH=/api/v3/getLiveStation
RAILSETU_RAIL_API_WINDOW_HOURS=3
RAILSETU_LIVE_MAX_TRAINS=30
RAILSETU_RAIL_API_CACHE_TTL_S=120
RAILSETU_RAIL_API_TIMEOUT_S=20
RAILSETU_RAIL_API_RETRIES=2

# ---- Live demand estimation (these APIs return no passenger counts) ----
RAILSETU_DEFAULT_ALIGHTING_PER_TRAIN=1200
RAILSETU_SPECIAL_TRAIN_MULTIPLIER=2.2
RAILSETU_UNLOAD_DURATION_S=180
RAILSETU_LIVE_HORIZON_S=420

# ---- Crowd sensing / calibration ----
# "none" or "stub". The stub reads observations from the fixture below.
RAILSETU_CROWD_SENSOR=none
RAILSETU_CROWD_SENSOR_FIXTURE=fixtures/crowd_observations.sample.json
RAILSETU_CALIBRATION_ENABLED=false
RAILSETU_CALIBRATION_MIN_SCALE=0.3
RAILSETU_CALIBRATION_MAX_SCALE=2.5
